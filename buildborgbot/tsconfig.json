{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "strictPropertyInitialization": true,
    "noUncheckedIndexedAccess": false,
    "noPropertyAccessFromIndexSignature": false,
    "exactOptionalPropertyTypes": true,
    "lib": ["ESNext"],
    "skipLibCheck": true,
    "types": ["@cloudflare/workers-types", "node"]
  }
}
